                                 ; ? FIXED ADC READING - PROPER WAY
                                 Read_Current:
                                     ; Start conversion
0000c1 ec06                          LDI temp, (1<<ADEN)|(1<<ADSC)|(1<<ADPS2)|(1<<ADPS1)
0000c2 b906                          OUT ADCSRA, temp
                                     
                                     ; Wait for conversion to complete
                                 Wait_ADC:
0000c3 9936                          SBIC ADCSRA, ADSC
0000c4 cffe                          RJMP Wait_ADC
                                     
                                     ; ? MUST READ ADCL FIRST, THEN ADCH
0000c5 b184                          IN current_reading, ADCL    ; Read low byte FIRST
0000c6 b105                          IN temp, ADCH               ; Read high byte SECOND
                                     
                                     ; For testing - manual value (comment out when using actual ADC)
                                     ; LDI current_reading, 65   ; Testing ke liye
                                     
0000c7 9508                          RET
                                 
